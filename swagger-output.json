{
  "swagger": "2.0",
  "info": {
    "title": "Fleet Management API",
    "description": "API documentation for the Fleet Management system",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "securityDefinitions": {
    "bearerAuth": {
      "type": "apiKey",
      "in": "header",
      "name": "Authorization",
      "description": "Enter your Bearer token in the format **Bearer &lt;token&gt;**"
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "User Login",
        "description": "Authenticate and receive a JWT access and refresh token.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Credentials to login",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "username": {
                  "type": "string",
                  "example": "admin"
                },
                "password": {
                  "type": "string",
                  "example": "password123"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/vehicles": {
      "post": {
        "tags": [
          "Vehicles"
        ],
        "summary": "Register New Vehicle",
        "description": "Add a new vehicle to the fleet management system.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "New vehicle payload",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "license_plate": {
                  "type": "string",
                  "example": "กค 1234"
                },
                "type": {
                  "type": "string",
                  "example": "TRUCK"
                },
                "status": {
                  "type": "string",
                  "example": "IDLE"
                },
                "driver_id": {
                  "type": "string",
                  "example": "drv_001"
                },
                "context": {
                  "type": "object",
                  "properties": {
                    "brand": {
                      "type": "string",
                      "example": "Isuzu"
                    },
                    "model": {
                      "type": "string",
                      "example": "D-Max"
                    },
                    "year": {
                      "type": "string",
                      "example": "2022"
                    },
                    "fuel_type": {
                      "type": "string",
                      "example": "DIESEL"
                    },
                    "mileage_km": {
                      "type": "number",
                      "example": 15400
                    },
                    "last_service_km": {
                      "type": "number",
                      "example": 10000
                    },
                    "next_service_km": {
                      "type": "number",
                      "example": 20000
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      },
      "get": {
        "tags": [
          "Vehicles"
        ],
        "summary": "List All Vehicles",
        "description": "Fetch all fleet vehicles including current status and assigned drivers.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/dashboard": {
      "get": {
        "tags": [
          "Dashboard"
        ],
        "summary": "Get Dashboard Overview Stats",
        "description": "Fetch real-time stats for fleet, trips, and maintenance alerts.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Dashboard stats payload"
          }
        }
      }
    },
    "/charts/vehicles-by-status": {
      "get": {
        "tags": [
          "Charts"
        ],
        "summary": "Vehicle Status Chart",
        "description": "Counts of vehicles grouped by their operational status.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/charts/trip-distance-trend": {
      "get": {
        "tags": [
          "Charts"
        ],
        "summary": "Trip Distance Trend",
        "description": "Distance covered over the last 7 days.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/drivers": {
      "get": {
        "tags": [
          "Drivers"
        ],
        "summary": "List All Drivers",
        "description": "Fetch all registered drivers sorted by name.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Drivers"
        ],
        "summary": "Register New Driver",
        "description": "Add a new driver to the system. Phone must be 10 digits and license must be 9 digits.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "New driver payload",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Somchai Jaidee"
                },
                "license_number": {
                  "type": "string",
                  "example": "123456789"
                },
                "license_expires_at": {
                  "type": "string",
                  "example": "2030-12-31"
                },
                "phone": {
                  "type": "string",
                  "example": "0812345678"
                },
                "status": {
                  "type": "string",
                  "example": "ACTIVE"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/drivers/{id}": {
      "patch": {
        "tags": [
          "Drivers"
        ],
        "summary": "Update Driver Info (Admin)",
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Update fields",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Somchai Jaidee"
                },
                "license_number": {
                  "type": "string",
                  "example": "123456789"
                },
                "license_expires_at": {
                  "type": "string",
                  "example": "2030-12-31"
                },
                "phone": {
                  "type": "string",
                  "example": "0812345678"
                },
                "status": {
                  "type": "string",
                  "example": "INACTIVE"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Drivers"
        ],
        "summary": "Delete Driver",
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Refresh Access Token",
        "description": "",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Previously acquired refresh token",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "refresh_token": {
                  "type": "string",
                  "example": "eyJhbGciOiJIUz..."
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register User",
        "description": "Helper route to register users (Test only).",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Desired user credentials",
            "schema": {
              "type": "object",
              "properties": {
                "username": {
                  "type": "string",
                  "example": "newadmin"
                },
                "password": {
                  "type": "string",
                  "example": "password123"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/vehicles/{id}": {
      "patch": {
        "tags": [
          "Vehicles"
        ],
        "summary": "Update Vehicle Status & Driver",
        "description": "Update vehicle operational status and driver assignment.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Fields to update",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "MAINTENANCE"
                },
                "driver_id": {
                  "type": "string",
                  "example": "drv_002"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Vehicles"
        ],
        "summary": "Delete Vehicle",
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/vehicles/{id}/details": {
      "patch": {
        "tags": [
          "Vehicles"
        ],
        "summary": "Update Vehicle Info (Admin)",
        "description": "Update internal vehicle configuration (License, Type, etc).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "New configuration payload",
            "schema": {
              "type": "object",
              "properties": {
                "license_plate": {
                  "type": "string",
                  "example": "ญข 9999"
                },
                "type": {
                  "type": "string",
                  "example": "VAN"
                },
                "brand": {
                  "type": "string",
                  "example": "Toyota"
                },
                "model": {
                  "type": "string",
                  "example": "Commuter"
                },
                "year": {
                  "type": "number",
                  "example": 2023
                },
                "fuel_type": {
                  "type": "string",
                  "example": "DIESEL"
                },
                "mileage_km": {
                  "type": "number",
                  "example": 18000
                },
                "next_service_km": {
                  "type": "number",
                  "example": 25000
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/vehicles/{id}/history": {
      "get": {
        "tags": [
          "Vehicles"
        ],
        "summary": "Vehicle Use History",
        "description": "Fetch prior trips and maintenance logs for this specific vehicle.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/maintenance": {
      "get": {
        "tags": [
          "Maintenance"
        ],
        "summary": "Get Maintenance Records",
        "description": "Fetch all maintenance records combined with vehicle details.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/trips": {
      "get": {
        "tags": [
          "Trips"
        ],
        "summary": "List All Trips",
        "description": "Fetch a list of all historical and active trips.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Trips"
        ],
        "summary": "Create New Trip",
        "description": "Dispatch a new trip with a specified vehicle, driver, and checkpoints.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "New trip payload",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "vehicle_id": {
                  "type": "string",
                  "example": "veh_001"
                },
                "driver_id": {
                  "type": "string",
                  "example": "drv_001"
                },
                "origin": {
                  "type": "string",
                  "example": "Bangkok"
                },
                "destination": {
                  "type": "string",
                  "example": "Chiang Mai"
                },
                "distance_km": {
                  "type": "number",
                  "example": 700
                },
                "cargo_type": {
                  "type": "string",
                  "example": "GENERAL"
                },
                "cargo_weight_kg": {
                  "type": "number",
                  "example": 5000
                },
                "checkpoints": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "location_name": {
                        "type": "string",
                        "example": "Nakhon Sawan"
                      },
                      "latitude": {
                        "type": "number",
                        "example": 15.69
                      },
                      "longitude": {
                        "type": "number",
                        "example": 100.12
                      },
                      "purpose": {
                        "type": "string",
                        "example": "Refuel"
                      }
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/trips/{id}": {
      "get": {
        "tags": [
          "Trips"
        ],
        "summary": "Get Trip Details",
        "description": "Fetch specific trip details along with its checkpoints.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Trips"
        ],
        "summary": "Delete Trip",
        "description": "Remove trip and its associated checkpoints.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/trips/{id}/status": {
      "patch": {
        "tags": [
          "Trips"
        ],
        "summary": "Update Trip Status",
        "description": "Change trip execution status (e.g. SCHEDULED -> IN_PROGRESS).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Trip status change",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "IN_PROGRESS"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/checkpoints/{id}/status": {
      "patch": {
        "tags": [
          "Checkpoints"
        ],
        "summary": "Update Checkpoint Status",
        "description": "Update sequential status of a trip checkpoint (PENDING -> ARRIVED -> DEPARTED).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Checkpoint status updates",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "ARRIVED"
                },
                "notes": {
                  "type": "string",
                  "example": "Driver took a 30m break."
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/alerts": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Get Alerts",
        "description": "Fetch system-generated alerts (WARNING/CRITICAL).",
        "parameters": [
          {
            "name": "severity",
            "in": "query",
            "type": "string"
          },
          {
            "name": "resource_type",
            "in": "query",
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/audit-logs": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Get Audit Logs",
        "description": "Fetch append-only security and operational audit logs.",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "type": "string"
          },
          {
            "name": "action",
            "in": "query",
            "type": "string"
          },
          {
            "name": "resource_type",
            "in": "query",
            "type": "string"
          },
          {
            "name": "start_date",
            "in": "query",
            "type": "string"
          },
          {
            "name": "end_date",
            "in": "query",
            "type": "string"
          },
          {
            "name": "limit",
            "in": "query",
            "type": "string"
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/{*path}": {
      "get": {
        "description": "",
        "parameters": [
          {
            "name": "*path",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  }
}